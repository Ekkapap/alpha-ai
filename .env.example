# Copy this file to .env and fill in the values for your machine.
# The .env file is gitignored — never commit it.

# ── Project root ──────────────────────────────────────────────────────────────
# Absolute path to the directory that CONTAINS the α/ folder.
#
#   macOS / Linux:
#     HOST_PROJECT_ROOT=/home/you/projects/my-project
#
#   Windows (Docker Desktop + WSL2) — use forward slashes:
#     HOST_PROJECT_ROOT=C:/Users/you/projects/my-project
#
HOST_PROJECT_ROOT=E:/NPM-Github/alpha-ai

# ── Container platform ────────────────────────────────────────────────────────
# Must match the architecture of the Go binaries in agents-resource/tools/bin/linux/
#
#   macOS Apple Silicon (M1/M2/M3)  →  linux/arm64
#   macOS Intel                      →  linux/amd64
#   Linux x86-64                     →  linux/amd64
#   Linux ARM64                      →  linux/arm64
#   Windows x86-64 (Docker Desktop)  →  linux/amd64
#
PLATFORM=linux/amd64

# ── Dashboard ports (optional) ────────────────────────────────────────────────
# DASHBOARD_PORT=8080
# UNDERSTAND_PORT=5173