FROM python:3.12-slim

# Install graphify pip package
RUN pip install --no-cache-dir graphifyy

# Our Go graphify MCP binary (built for linux/amd64)
COPY bin/linux/graphify /usr/local/bin/graphify
RUN chmod +x /usr/local/bin/graphify

WORKDIR /project

# Default: MCP server (stdio) — overridden by compose for specific commands
ENTRYPOINT ["graphify"]
